{
	"name": "pandora-cli",
	"version": "0.1.0",
	"private": true,
	"license": "LGPL-3.0-or-later",
	"engines": {
		"node": ">=24.x"
	},
	"type": "module",
	"bin": {
		"pandora-cli": "./dist/index.js"
	},
	"files": [
		"/dist/**/*"
	],
	"scripts": {
		"pandora-cli": "node ./dist/index.js",
		"clean": "rimraf dist coverage",
		"build": "rimraf dist && tsc -p ./tsconfig.json",
		"dev": "rimraf dist && tsc -p ./tsconfig.json -w --skipLibCheck",
		"lint": "eslint --max-warnings 0 .",
		"lint:fix": "eslint --fix .",
		"type-check": "pnpm run '/type-check:.*/'",
		"type-check:test": "tsc -p ./test/tsconfig.json --noEmit",
		"type-check:src": "tsc -p ./tsconfig.json --noEmit",
		"test": "jest",
		"test:coverage": "jest --coverage",
		"test:watch": "jest --watch",
		"prepack": "pnpm run build"
	},
	"dependencies": {
		"pandora-api": "workspace:*",
		"pandora-common": "workspace:*"
	},
	"devDependencies": {
		"@jest/globals": "30.4.1",
		"@types/node": "24.13.3",
		"jest": "30.4.2",
		"pandora-common": "workspace:*",
		"rimraf": "6.1.3",
		"ts-jest": "29.4.11",
		"tslib": "2.8.1",
		"typescript": "6.0.3"
	}
}
